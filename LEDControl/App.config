<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    User settings are persisted to user.config in %LocalAppData% by
    System.Configuration.ConfigurationManager. Default values come from the
    [DefaultSettingValue] attributes in Properties\Settings.Designer.cs, so no
    <configSections>/<userSettings> block is required here.
  -->
</configuration>
